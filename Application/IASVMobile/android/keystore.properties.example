# Modèle pour android/keystore.properties
# Copier ce fichier en `keystore.properties` (sans le suffixe .example)
# et remplir les valeurs réelles. Le vrai fichier est gitignoré.
#
# IMPORTANT (sécurité) :
# - Ne JAMAIS committer le vrai keystore.properties
# - Ne JAMAIS committer release-key.keystore (pattern *.keystore déjà ignoré)
# - Stocker la clé + ses mots de passe dans un coffre (1Password, Bitwarden, GCP Secret Manager…)
# - Pour la CI, injecter ces valeurs via variables d'environnement et générer
#   ce fichier au moment du build.

MYAPP_UPLOAD_STORE_FILE=release-key.keystore
MYAPP_UPLOAD_KEY_ALIAS=myappkey
MYAPP_UPLOAD_STORE_PASSWORD=__REPLACE_ME__
MYAPP_UPLOAD_KEY_PASSWORD=__REPLACE_ME__
